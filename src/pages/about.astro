---
import Layout from '../layouts/Layout.astro';
import { TEMPLATE_CONFIG } from '../config';
---

<Layout title={`About | ${TEMPLATE_CONFIG.site.title}`} description="About this starter template.">
	<div class="shell">
		<section class="section">
			<div class="section-head">
				<p class="eyebrow">About</p>
				<h1>About</h1>
				<p>This is a starter blog template based on Astro. Use this as a foundation for your own site.</p>
			</div>

			<div class="page-grid">
				<article class="page-card">
					<p class="page-title">About this blog</p>
					<p>
						This blog is built using Astro, a modern static site generator. It serves as a starting point for creating your own technical notes or blog posts. The template is designed to be simple and easy to customize, allowing you to focus on your content.
					</p>
				</article>

				<article class="page-card">
					<p class="page-title">Article Theme</p>
					<p>
						The articles in this template are intended to be technical notes or blog posts. You can write about programming, technology, or any topic you like. The template supports Markdown for easy content creation and formatting.
					</p>
				</article>
			</div>

			<article class="page-card page-card-wide">
				<p class="page-title">Update Frequency</p>
				<p>
					We aim to update the blog once a week. New articles and important updates will be announced on the homepage and social media.
				</p>
			</article>

			<article class="page-card page-card-wide">
				<p class="page-title">Privacy Policy and Disclaimer</p>
				<p>
					This site does not intentionally collect personal information that can identify individuals, and we do not intentionally disseminate false information. Additionally, any information provided during inquiries will not be used for purposes other than responding to those inquiries.<br>
					For more information about our privacy policy and disclaimer, please visit our <a href="/policy" class="link">policy page</a>.
				</p>
			</article>

		
		</section>
	</div>
</Layout>