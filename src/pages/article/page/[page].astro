---
import Layout from '../../../layouts/Layout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { collectArticles } from '../../../utils/articles';

type ArticleFrontmatter = {
	title: string;
	description: string;
	pubDate: string;
	author: string;
	tags?: string[] | string;
	img?: string;
};

const PAGE_SIZE = 12;

const modules = import.meta.glob('../*.md', { eager: true }) as Record<
	string,
	{ frontmatter: ArticleFrontmatter }
>;

const allArticles = collectArticles(modules);

const totalPages = Math.max(1, Math.ceil(allArticles.length / PAGE_SIZE));

export function getStaticPaths() {
	const pageSize = 12;
	const articleCount = Object.keys(import.meta.glob('../*.md')).length;
	const pages = Math.max(1, Math.ceil(articleCount / pageSize));

	return Array.from({ length: Math.max(0, pages - 1) }, (_, index) => {
		const page = index + 2;
		return {
			params: { page: String(page) },
		};
	});
}

const pageParam = Number(Astro.params.page ?? '1');
const currentPage = Number.isNaN(pageParam) ? 1 : pageParam;
const start = (currentPage - 1) * PAGE_SIZE;
const end = start + PAGE_SIZE;
const articles = allArticles.slice(start, end);

const makePagePath = (page: number) => (page === 1 ? '/article' : `/article/page/${page}`);
---

<Layout title={`Article ${currentPage} | Nexiary`} description="Nexiary の記事一覧ページです。">
	<div class="shell">
		<section class="section">
			<div class="section-head split">
				<div>
					<p class="eyebrow">Article</p>
					<h1>記事一覧</h1>
				</div>
				<p class="results-summary">{articles.length}件表示中</p>
			</div>

			<div class="post-grid article-grid">
				{articles.map((article) => (
					<ArticleCard
						title={article.title}
						date={article.pubDate}
						description={article.description}
						slug={article.slug}
						tags={article.tags}
						img={article.img}
					/>
				))}
			</div>

			<nav class="pagination" aria-label="記事一覧ページネーション">
				{Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
					<a class:list={["page-link", page === currentPage && 'is-current']} href={makePagePath(page)}>
						{page}
					</a>
				))}
			</nav>
		</section>
	</div>
</Layout>