---
import Layout from '../../../layouts/Layout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { TEMPLATE_CONFIG } from '../../../config';
import { collectArticles } from '../../../utils/articles';

const PAGE_SIZE = TEMPLATE_CONFIG.content.pageSize;

const allArticles = await collectArticles();
const totalPages = Math.max(1, Math.ceil(allArticles.length / PAGE_SIZE));

export async function getStaticPaths() {
	const allArticles = await collectArticles();
	const pageSize = TEMPLATE_CONFIG.content.pageSize;
	const pages = Math.max(1, Math.ceil(allArticles.length / pageSize));

	return Array.from({ length: Math.max(0, pages - 1) }, (_, index) => {
		const page = index + 2;
		return {
			params: { page: String(page) },
		};
	});
}

const pageParam = Number(Astro.params.page ?? '1');
const currentPage = Number.isNaN(pageParam) ? 1 : pageParam;
const start = (currentPage - 1) * PAGE_SIZE;
const end = start + PAGE_SIZE;
const articles = allArticles.slice(start, end);

const makePagePath = (page: number) => (page === 1 ? '/article' : `/article/page/${page}`);
---

<Layout title={`Article ${currentPage} | ${TEMPLATE_CONFIG.site.title}`} description="Article list for the starter template.">
	<div class="shell">
		<section class="section">
			<div class="section-head split">
				<div>
					<p class="eyebrow">Article</p>
					<h1>Article List</h1>
				</div>
				<p class="results-summary">{articles.length} results</p>
			</div>

			<div class="post-grid article-grid">
				{articles.map((article) => (
					<ArticleCard
						title={article.data.title}
						date={article.data.pubDate}
						description={article.data.description}
						slug={article.slug}
						tags={article.tags}
						img={article.data.img}
					/>
				))}
			</div>

			<nav class="pagination" aria-label="Article pagination">
				{Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
					<a class:list={["page-link", page === currentPage && 'is-current']} href={makePagePath(page)}>
						{page}
					</a>
				))}
			</nav>
		</section>
	</div>
</Layout>