---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { collectArticles, uniqueTags } from '../utils/articles';

const allArticles = await collectArticles();
const latestArticles = allArticles.slice(0, 6);

const articleCount = allArticles.length;
const tagCount = uniqueTags(allArticles).length;

const featureCards = [
	{
		title: 'Article',
		description: 'Explore our collection of technical articles and blog posts.',
		href: '/article',
		label: 'Open',
	},
	{
		title: 'About',
		description: 'Learn more about the blog and its purpose.',
		href: '/about',
		label: 'Open',
	},
	{
			title: 'Contact',
			description: 'Contact us through our inquiry form.',
			href: 'https://forms.gle/sW5eP28BkmsYY2Xw8',
		label: 'Open',
	},
	{
		title: 'Policy',
		description: 'Privacy policy and disclaimer information.',
		href: '/policy',
		label: 'Open',
	},
];
---

<Layout title="StarterBlog | Knowledge Feed" description="A starter blog template for Astro." >
	<div class="shell">
		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">Home / TECH NOTES</p>
				<h1>StarterBlog</h1>
				<p class="lead">A starter template for technical notes and blog posts.</p>
				<div class="actions">
					<a class="button primary" href="/article">Article</a>
					<a class="button ghost" href="/about">About</a>
				</div>
			</div>

			<aside class="hero-card" aria-label="Site overview">
				<p class="card-kicker">Welcome</p>
				<p>
					Welcome to StarterBlog, a simple and customizable blog template built with Astro. This site serves as a foundation for creating your own technical notes or blog posts. Explore our collection of articles, learn about the blog's purpose, and feel free to contact us for any inquiries.
				</p>
				<div class="stats">
					<div>
						<strong>{articleCount}</strong>
						<span>Articles</span>
					</div>
					<div>
						<strong>{tagCount}</strong>
						<span>Tags</span>
					</div>
					<div>
						<strong>{latestArticles.length}</strong>
						<span>Latest Articles</span>
					</div>
				</div>
			</aside>
		</section>

		<section class="section">
			<div class="section-head">
				<p class="eyebrow">Pages</p>
				<h2>Visit Our Pages</h2>
				<p>Explore the different sections of our site.</p>
			</div>

			<div class="page-grid">
				{featureCards.map((page) => (
					<article class="page-card">
						<p class="page-title">{page.title}</p>
						<p>{page.description}</p>
						<a href={page.href}>{page.label}</a>
					</article>
				))}
			</div>
		</section>

		<section class="section">
			<div class="section-head split">
				<div>
					<p class="eyebrow">Latest Posts</p>
					<h2>Latest Articles</h2>
				</div>
				<a class="button ghost" href="/article">View More</a>
			</div>

			<div class="post-grid article-grid">
				{latestArticles.map((article) => (
					<ArticleCard
						title={article.data.title}
						date={article.data.pubDate}
						description={article.data.description}
						slug={article.slug}
						tags={article.tags}
						img={article.data.img}
					/>
				))}
			</div>
		</section>
	</div>
</Layout>
