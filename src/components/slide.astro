---
import htmlLogo from '../assets/stacks/HtmlLogo.png';
import cssLogo from '../assets/stacks/CssLogo.png';
import jsLogo from '../assets/stacks/JavascriptLogo.png';
import gitLogo from '../assets/stacks/GitLogo.png';
import githubLogo from '../assets/stacks/GithubLogo.png';
import gasLogo from '../assets/stacks/GasLogo.png';
import unityLogo from '../assets/stacks/UnityLogo.png';

const stacks = [
	{ name: 'HTML', image: htmlLogo },
	{ name: 'CSS', image: cssLogo },
	{ name: 'JavaScript', image: jsLogo },
	{ name: 'Git', image: gitLogo },
	{ name: 'GitHub', image: githubLogo },
	{ name: 'Google Apps Script', image: gasLogo },
	{ name: 'Unity', image: unityLogo },
];

// 無限ループ用に配列を複製
const stacksLooped = [...stacks, ...stacks, ...stacks];
---

<div class="slide-container">
	<button class="slide-nav-button slide-nav-prev" data-slide-prev aria-label="前へ">
		<span>‹</span>
	</button>
	
	<div class="slide-wrapper">
		<div class="slide-carousel" data-slide-carousel>
			{stacksLooped.map((stack) => (
				<div class="slide-card">
					<div class="slide-card-inner">
						<img src={stack.image.src} alt={stack.name} class="slide-image" />
						<p class="slide-name">{stack.name}</p>
					</div>
				</div>
			))}
		</div>
	</div>
	
	<button class="slide-nav-button slide-nav-next" data-slide-next aria-label="次へ">
		<span>›</span>
	</button>
</div>

<style>
	.slide-container {
		display: flex;
		align-items: center;
		gap: 1rem;
		justify-content: space-between;
	}

	.slide-wrapper {
		flex: 1;
		overflow: hidden;
		/* ポイント：wrapperのサイズを固定する */
		width: 100%;
		max-width: 800px;
	}

	.slide-carousel {
		display: flex;
		gap: 1.5rem;
		padding: 1.5rem 0.5rem;
		
		/* スクロールバーを非表示 */
		scrollbar-width: none;
		-ms-overflow-style: none;

		/* 無限スクロールアニメーション */
		animation: infiniteScroll 40s linear infinite;

		&::-webkit-scrollbar {
			display: none;
		}

		&.paused {
			animation-play-state: paused;
		}
	}

	/* ポイント：3セット目が1セット目の位置に来たとき、
	   スムーズに最初に戻るようなアニメーション */
	@keyframes infiniteScroll {
		0% {
			transform: translateX(0);
		}
		100% {
			/* 7カード分のスクロール距離（164px × 7 = 1148px × 2セット分 = 2296px） */
			transform: translateX(-2296px);
		}
	}

	.slide-card {
		flex: 0 0 auto;
		width: 140px;
	}

	.slide-card-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding: 1.5rem;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(248, 250, 252, 0.7));
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 16px;
		box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		cursor: pointer;
		height: 100%;
		justify-content: center;
	}

	.slide-card:hover .slide-card-inner {
		transform: translateY(-8px);
		box-shadow: 0 12px 24px rgba(15, 23, 42, 0.12);
	}

	.slide-image {
		width: 80px;
		height: 80px;
		object-fit: contain;
		transition: transform 0.3s ease;
	}

	.slide-card:hover .slide-image {
		transform: scale(1.1);
	}

	.slide-name {
		font-size: 0.85rem;
		font-weight: 600;
		text-align: center;
		color: #0f172a;
		margin: 0;
		letter-spacing: 0.3px;
	}

	.slide-nav-button {
		flex: 0 0 auto;
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1.5px solid rgba(15, 23, 42, 0.12);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(248, 250, 252, 0.7));
		border-radius: 12px;
		cursor: pointer;
		transition: all 0.3s ease;
		font-size: 1.5rem;
		line-height: 1;
		color: #0f172a;

		&:hover {
			background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(248, 250, 252, 0.85));
			border-color: #0f172a;
			transform: scale(1.05);
		}

		&:active {
			transform: scale(0.95);
		}
	}
</style>

<script>
	const container = document.querySelector('[data-slide-carousel]') as HTMLElement;
	const btnPrev = document.querySelector('[data-slide-prev]') as HTMLElement;
	const btnNext = document.querySelector('[data-slide-next]') as HTMLElement;

	if (container) {
		// ホバーでアニメーション一時停止
		container.addEventListener('mouseenter', () => {
			container.classList.add('paused');
		});

		container.addEventListener('mouseleave', () => {
			container.classList.remove('paused');
		});

		// スクロール中のフラグ
		let isScrolling = false;

		// ボタンクリック時もアニメーション一時停止（スクロール可能）
		const handleButtonClick = (direction: 'prev' | 'next') => {
			if (isScrolling) return;
			
			isScrolling = true;
			container.classList.add('paused');
			
			const cardWidth = 140;
			const gap = 24;
			const scrollDistance = cardWidth + gap;

			if (direction === 'next') {
				container.scrollBy({ left: scrollDistance, behavior: 'smooth' });
			} else {
				container.scrollBy({ left: -scrollDistance, behavior: 'smooth' });
			}

			// スクロール完了後にアニメーション再開
			setTimeout(() => {
				isScrolling = false;
				container.classList.remove('paused');
				// CSSアニメーションを強制的に再スタート
				container.style.animation = 'none';
				void container.offsetWidth;
				container.style.animation = '';
			}, 700);
		};

		btnPrev?.addEventListener('click', () => handleButtonClick('prev'));
		btnNext?.addEventListener('click', () => handleButtonClick('next'));
	}
</script>
