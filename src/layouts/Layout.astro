---
import '../styles/global.css';

const siteIcon = '/favicon.ico';

const {
	title = 'StarterBlog',
	description = 'A starter Astro blog template.',
} = Astro.props;

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/article', label: 'Article' },
	{ href: '/about', label: 'About' },
	{ href: '/policy', label: 'Policy' },
	{ href: '/', label: 'Contact' },
];
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0f172a" />
		<title>{title}</title>
		<link rel="icon" href={siteIcon} />
	</head>
	<body>
		<header class="site-header">
			<div class="site-header-inner">
				<a class="site-brand" href="/" aria-label="StarterBlog home">
					<img src={siteIcon} alt="StarterBlog" class="site-brand-mark" />
					<span>
						<strong>StarterBlog</strong>
						<small>Starter Template</small>
					</span>
				</a>

				<nav class="site-nav" aria-label="Primary navigation">
					{navItems.map((item) => (
						<a
							href={item.href}
							target={item.href.startsWith('http') ? '_blank' : undefined}
							rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
						>
							{item.label}
						</a>
					))}
				</nav>
			</div>
		</header>

		<main class="site-main">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="site-footer-inner">
				<div>
					<p class="eyebrow">Additional Links</p>
					<div class="footer-links">
						{navItems.map((item) => (
							<a
								href={item.href}
								target={item.href.startsWith('http') ? '_blank' : undefined}
								rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
							>
								{item.label}
							</a>
						))}
					</div>
				</div>
				<div>
					<p class="site-footer-note">© 2026 StarterBlog</p>
					<p class="site-footer-note">
						This website is forked from
						<a href="https://github.com/hokke414/AstroBlogTemplate" target="_blank" rel="noreferrer">this repo</a>.
					</p>
				</div>
			</div>
		</footer>
	</body>
</html>
